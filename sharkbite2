local currentSide = 1
local sideResults = {{}, {}, {}, {}}
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude

local function getSharkCenter(shark)
	local boundingCF, boundingSize = shark:GetBoundingBox()
	local center = boundingCF.Position - Vector3.new(0, boundingSize.Y * 0.125, 0)

	rayParams.FilterDescendantsInstances = {character, shark}

	for i, angle in ipairs({0, 90, 180, 270}) do
		local rad = math.rad(angle)
		local dir = Vector3.new(math.cos(rad), 0, math.sin(rad))
		local result = workspace:Raycast(center, dir * 300, rayParams)
		sideResults[i].dist = result and result.Distance or 300
		sideResults[i].dir = dir
	end

	if sideResults[currentSide].dist < 200 then
		local bestSide, bestDist = currentSide, sideResults[currentSide].dist
		for i = 1, 4 do
			if sideResults[i].dist > bestDist then
				bestDist = sideResults[i].dist
				bestSide = i
			end
		end
		currentSide = bestSide
	end

	local best = sideResults[currentSide]
	return center + best.dir * best.dist
end

local function killShark()
	if sharkName and remote then
		local shark = sharksFolder:FindFirstChild(sharkName)
		if shark then
			remotesFolder:WaitForChild(remote):FireServer(shark, true)
		end
	end
end

