local vaseParts = {}
local vaseConnections = {}
local vaseConnection

local function addVasePart(part)
	table.insert(vaseParts, part)
	part.AncestryChanged:Connect(function(_, parent)
		if parent then return end
		for i = #vaseParts, 1, -1 do
			if vaseParts[i] == part then
				table.remove(vaseParts, i)
				break
			end
		end
	end)
end

